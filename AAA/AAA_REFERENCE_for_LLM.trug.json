    {
      "id": "two_paths",
      "type": "CONCEPT",
      "metric_level": "STANDARD",
      "parent_id": "aaa_framework",
      "properties": {
        "name": "Two Paths — CHORE or ISSUE",
        "description": "No middle ground. If it needs an issue, it needs an AAA. If it doesn't need an issue, it's a chore.",
        "chore": {"trigger": "Simple task, known steps, no unknowns", "flow": "Branch → PR → merge. No issue needed."},
        "issue": {"trigger": "Idea, proposal, feature, bug — anything with unknowns", "flow": "Issue → AAA → PLANNING → HITM → EXECUTION → PR → merge"}
      },
      "contains": [],
      "dimension": "aaa_structure"
    },
    {
      "id": "nine_phases",
      "type": "CONCEPT",
      "metric_level": "STANDARD",
      "parent_id": "aaa_framework",
      "properties": {
        "name": "Nine Development Phases in Two Cycles",
        "description": "PLANNING cycle (phases 1-5) and EXECUTION cycle (phases 6-9) separated by VALIDATION HITM gate",
        "planning_cycle": "VISION → FEASIBILITY → SPECIFICATIONS → ARCHITECTURE → VALIDATION (HITM)",
        "execution_cycle": "CODING → TESTING → AUDIT (HITM) → DEPLOYMENT",
        "phase_statuses": ["NOT_STARTED", "IN_PROGRESS", "COMPLETE", "BLOCKED", "NOT_APPLICABLE"],
        "quality_gates": ["passed", "pending", "blocked"],
        "compute_routing": "PLANNING cycle runs on expensive models (Opus). EXECUTION cycle can run on cheaper models (Sonnet/Haiku)."
      },
      "contains": ["phase_vision", "phase_feasibility", "phase_specifications", "phase_architecture", "phase_validation", "phase_coding", "phase_testing", "phase_audit", "phase_deployment"],
      "dimension": "aaa_structure"
    },
