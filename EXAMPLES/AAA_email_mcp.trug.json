      "properties": {
        "name": "Configuration Format",
        "location": "~/.config/trugs/email_accounts.json",
        "format": {
          "accounts": {
            "trugs": {
              "email": "admin@trugs.ai",
              "imap_host": "imap.gmail.com",
              "imap_port": 993,
              "smtp_host": "smtp.gmail.com",
              "smtp_port": 587,
              "password_env": "TRUGS_EMAIL_PASSWORD"
            }
          }
        },
