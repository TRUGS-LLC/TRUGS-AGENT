    {
      "id": "clause_parties",
      "type": "RECORD",
      "properties": {
        "name": "Section 1 — Parties",
        "section": 1,
        "purpose": "Identifies both parties and establishes mutual nature — each is both Disclosing and Receiving Party",
        "defines": ["Disclosing Party", "Receiving Party", "Party", "Parties"]
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_purpose",
      "type": "RECORD",
      "properties": {
        "name": "Section 2 — Purpose",
        "section": 2,
        "purpose": "Defines the business purpose for sharing confidential information — limits use to this purpose only",
        "defines": ["Purpose"]
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_definition",
      "type": "RECORD",
      "properties": {
        "name": "Section 3 — Definition of Confidential Information",
        "section": 3,
        "purpose": "Defines what information is protected — technical, business, financial data, marked or orally identified within 10 days",
        "defines": ["Confidential Information"],
        "includes": ["source code", "specifications", "algorithms", "business plans", "customer lists", "financial data", "marked materials", "oral disclosures identified in writing"]
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_exclusions",
      "type": "RECORD",
      "properties": {
        "name": "Section 4 — Exclusions",
        "section": 4,
        "purpose": "Carves out information that is NOT confidential — 4 standard exclusions required for enforceability",
        "exclusions": ["publicly available", "prior possession", "independently developed", "third party disclosure without restriction"]
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_obligations",
      "type": "RECORD",
      "properties": {
        "name": "Section 5 — Obligations of the Receiving Party",
        "section": 5,
        "purpose": "Core duties — protect with reasonable care, use only for Purpose, disclose only to authorized Representatives, responsible for Representative breaches",
        "obligations": ["protect with reasonable care", "use only for Purpose", "limit disclosure to Representatives", "responsible for Representative breaches"]
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_permitted",
      "type": "RECORD",
      "properties": {
        "name": "Section 6 — Permitted Disclosures",
        "section": 6,
        "purpose": "Allows disclosure when compelled by law — requires notice to Disclosing Party, cooperation on protective order, minimum disclosure",
        "conditions": ["required by law/regulation/court order", "must notify Disclosing Party", "cooperate on protective order", "disclose minimum required"]
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_term",
      "type": "RECORD",
      "properties": {
        "name": "Section 7 — Term and Termination",
        "section": 7,
        "purpose": "2-year term, 30-day termination notice, 3-year survival for confidentiality obligations, indefinite for trade secrets",
        "term_years": 2,
        "termination_notice_days": 30,
        "survival_years": 3,
        "trade_secret_survival": "indefinite"
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_return",
      "type": "RECORD",
      "properties": {
        "name": "Section 8 — Return of Materials",
        "section": 8,
        "purpose": "Return or destroy all Confidential Information within 10 days of termination or request — certify destruction, retain only legal/backup copies",
        "return_period_days": 10
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_remedies",
      "type": "RECORD",
      "properties": {
        "name": "Section 9 — Remedies",
        "section": 9,
        "purpose": "Acknowledges irreparable harm, allows injunctive relief without bond under RCW 19.108, preserves all other remedies",
        "remedies": ["injunctive relief", "no bond required", "all other remedies at law or equity"],
        "statute": "RCW 19.108"
      },
      "parent_id": "nda",
      "contains": [],
      "metric_level": "BASE_RECORD",
      "dimension": "legal"
    },
    {
      "id": "clause_whistleblower",
      "type": "RECORD",
      "properties": {
        "name": "Section 10 — Whistleblower Immunity Notice",
        "section": 10,
        "purpose": "Required DTSA notice — immunity for disclosures to government/attorneys for reporting suspected law violations",
        "statute": "18 U.S.C. § 1833(b)",
        "required_since": "2016"
      },
